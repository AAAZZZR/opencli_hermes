# opencli-admin backend (always localhost on VPS)
ADMIN_API_URL=http://localhost:8031

# Security
RATE_LIMIT_PER_NODE=10
RATE_LIMIT_GLOBAL=60
AUDIT_LOG_PATH=~/.fleet-mcp/audit.log
MAX_ITEMS_INLINE=50

# Timeouts (seconds)
TASK_TIMEOUT_SEC=120
BROADCAST_TIMEOUT_SEC=180
TASK_POLL_INTERVAL_SEC=2

# Node-site mapping file
NODE_SITES_PATH=node_sites.yaml

# Logging
LOG_LEVEL=INFO
