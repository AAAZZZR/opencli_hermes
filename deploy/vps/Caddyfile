# Caddy config for fleet-hub.
# Replace __PUBLIC_HOST__ with your sslip.io hostname, e.g. 34.46.31.68.sslip.io
# Caddy will auto-get Let's Encrypt certs on first boot.

__PUBLIC_HOST__ {
    encode zstd gzip

    # The installer endpoint at /api/v1/nodes/install/* embeds the node's
    # token in the returned bash script. Exposing it publicly means anyone
    # who guesses a label can download that node's token. Block it here —
    # run the installer fetch from inside the VPS instead:
    #   curl http://localhost:8031/api/v1/nodes/install/agent.sh?label=<label>
    @installer path /api/v1/nodes/install/*
    respond @installer 403 {
        body "installer endpoint is localhost-only. SSH to the VPS and curl http://localhost:8031/api/v1/nodes/install/agent.sh?label=<label>"
        close
    }

    # WebSocket upgrade for /api/v1/nodes/ws + regular REST proxy
    reverse_proxy localhost:8031 {
        header_up Host {upstream_hostport}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# Redirect bare IP / anything else to the sslip hostname (optional, keeps URLs stable)
:80, :443 {
    redir https://__PUBLIC_HOST__{uri} permanent
}
