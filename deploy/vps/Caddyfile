# Caddy config for fleet-hub.
# Replace __PUBLIC_HOST__ with your sslip.io hostname, e.g. 34.46.31.68.sslip.io.
# Caddy will auto-get Let's Encrypt certs on first boot.

__PUBLIC_HOST__ {
	encode zstd gzip

	# Public health check only.
	handle /health {
		reverse_proxy localhost:8031 {
			header_up Host {upstream_hostport}
			header_up X-Real-IP {remote_host}
		}
	}

	# Agent reverse WebSocket endpoint. Agents authenticate with their node token.
	handle /api/v1/nodes/ws {
		reverse_proxy localhost:8031 {
			header_up Host {upstream_hostport}
			header_up X-Real-IP {remote_host}
		}
	}

	# REST is intentionally localhost-only. It has no auth because fleet-mcp
	# talks to it over localhost and applies command policy before dispatch.
	handle /api/v1/* {
		respond 403 {
			body "fleet-hub REST API is localhost-only. SSH to the VPS and use http://localhost:8031"
			close
		}
	}

	handle {
		respond 404
	}
}

# Redirect bare IP / anything else to the sslip hostname.
:80, :443 {
	redir https://__PUBLIC_HOST__{uri} permanent
}
