# fleet-agent runtime config — this file is what install-agent.sh writes to
# ~/.fleet-agent/config.env. Source it or point FLEET_AGENT_CONFIG at it.

CENTRAL_URL=https://fleet.yourdomain.com
NODE_TOKEN=replace-me
NODE_LABEL=alice-mbp

OPENCLI_BIN=opencli
AGENT_MODE=bridge

# Optional
WS_RECONNECT_MIN_SEC=3
WS_RECONNECT_MAX_SEC=60
WS_PING_INTERVAL_SEC=30
WS_PING_TIMEOUT_SEC=10

# Detection probe timeout (seconds) — how long `opencli <site> hot -f json` runs
# during login detection at WS register time.
LOGIN_PROBE_TIMEOUT_SEC=10

LOG_LEVEL=INFO
